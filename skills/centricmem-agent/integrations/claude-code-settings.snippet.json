{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "centricmem ambient --write"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "centricmem log-session --auto --title hooks && centricmem index --all --quiet"
          }
        ]
      }
    ]
  }
}
